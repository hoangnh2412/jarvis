    <ProjectReference Include="..\Jarvis.Authentication.ApiKey\Jarvis.Authentication.ApiKey.csproj" />
    <ProjectReference Include="..\Jarvis.BlobStoring.FileSystem\Jarvis.BlobStoring.FileSystem.csproj" />
