{
  "ConnectionStrings": {
    "AutoMigrate": "true",
    "SampleDbContext": "Host=localhost;Port=5432;User ID=admin;Password=Admin@123;Database=Jarvis;Pooling=true;"
  },
  "Cache": {
    "DefaultDistgroup": "Default",
    "DefaultDistType": "Redis",
    "DistGroups": {
      "Redis": {
        "Default": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "Instance1_"
        },
        "Auth": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "SharedAuth1_"
        },
        "Big": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "Instance3_"
        }
      }
    },
    "Items": {
      "ContextData": {
        "Key": "context_{sid}",
        "DistSeconds": 14400,
        "MemSeconds": 180,
        "DistGroup": "Auth",
        "Note": "Thông tin phiên đăng nhập. Được khởi tạo tại AuthApi"
      },
      "NoDistAndMemSeconds": {
        "Key": "conn_{dbid}",
        "Note": "Chuỗi kết nối vào dữ liệu"
      },
      "NoDist": {
        "Key": "conn_{dbid}",
        "MemSeconds": 14400,
        "Note": "Chuỗi kết nối vào dữ liệu"
      },
      "NoKey": {
        "Key": "",
        "MemSeconds": 14400,
        "Note": "Chuỗi kết nối vào dữ liệu"
      },
      "NoMem": {
        "Key": "index_{custom}",
        "DistSeconds": 14400,
        "Note": "Nội dung html trả về client"
      },
      "DistAndMem": {
        "Key": "context_{sid}",
        "DistSeconds": 14400,
        "MemSeconds": 180,
        "DistGroup": "Auth",
        "Note": "Thông tin phiên đăng nhập. Được khởi tạo tại AuthApi"
      },
      "DistAndMemNoExpire": {
        "Key": "context_{sid}",
        "DistGroup": "Auth",
        "Note": "Thông tin phiên đăng nhập. Được khởi tạo tại AuthApi"
      },
      "AuthUserInfo": {
        "Key": "Auth:UserInfo_{uname}_{appType}",
        "DistGroup": "Auth",
        "MemSeconds": 180,
        "DistSeconds": 14400,
        "Note": "Thông người dùng đăng nhập theo username"
      }
    }
  },
  "Authentication": {
    "Type": "ApiKey",
    "ApiKey": {
      "Default": {
        "KeyName": "X-API-KEY",
        "Keys": [
          "ZofkXgxwiO6F2s1JJCX5L6Wa7JctPmpO"
        ]
      }
    },
    "Cognito": {
      "Endpoint": "https://cognito-idp.us-east-1.amazonaws.com",
      "Region": "us-east-1",
      "UserPools": {
        "key": "value"
      }
    }
  },
  "Json": {
    "IgnoreNull": true,
    "NamingPolicy": "CamelCase"
  },
  "Swagger": {
    "Enable": true,
    "Versions": [
      "v1",
      "v2"
    ],
    "SecuritySchemes": [
      "JWT",
      "API_KEY"
    ]
  },
  "Middlewares": {
    "ApiResponseWrapper": {
      "IsEnable": true,
      "Includes": [
        "^/api"
      ],
      "Excludes": [
        "^.*\\.js$",
        "^.*\\.css$",
        "^.*\\/health$",
        "^.*\\/swagger$"
      ]
    }
  },
  "Cors": {
    "Default": {
      "AllowAnyOrigin": true,
      "AllowedOrigins": [],
      "AllowedAllHeaders": true,
      "AllowedHeaders": [],
      "AllowedAllMethods": true,
      "AllowedMethods": [],
      "AllowCredentials": false
    }
  },
  "OTEL": {
    "Name": "sample-code",
    "Namespace": "sample-code-namespace",
    "InstanceId": "hoangnh",
    "Resource": {
      "IncludeHostDetector": true,
      "IncludeContainerDetector": true
    },
    "Attributes": {},
    "Logging": {
      "IncludeConsoleExporter": false,
      "Endpoint": "http://localhost:14317",
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    },
    "Tracing": {
      "Endpoint": "http://localhost:14317",
      "Sampler": "ParentBasedRatio",
      "TraceIdRatio": 1.0,
      "TimeoutMilliseconds": 10000,
      "BatchExportProcessorOptions": {
        "ScheduledDelayMilliseconds": 5000
      },
      "HttpTraceEnrichment": {
        "CaptureRequestHeaders": true,
        "CaptureResponseHeaders": true,
        "AllowedRequestHeaderNames": [
          "traceparent",
          "tracestate",
          "x-request-id",
          "x-correlation-id",
          "x-demo-request"
        ],
        "AllowedResponseHeaderNames": [
          "content-type",
          "api-supported-versions",
          "x-demo-response"
        ],
        "MaxHeaderValueLength": 256
      },
      "AspNetCoreInstrumentation": {
        "RecordException": true,
        "ExcludedPathPrefixes": [
          "/health",
          "/healthchecks",
          "/swagger"
        ]
      },
      "HttpClient": {
        "ExcludedUrlSubstrings": []
      }
    },
    "Metric": {
      "Endpoint": "http://localhost:14317",
      "HistogramAggregation": "explicit",
      "IncludeConsoleExporter": false
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sample-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "HealthChecks": {
    "MemoryThresholdPercent": 80,
    "CpuThresholdPercent": 90,
    "ResultCacheMilliseconds": 100,
    "DetailedEndpointApiKey": "",
    "EnablePrometheusMetrics": true,
    "PrometheusMetricsPath": "/health/prometheus",
    "DefaultTimeoutSeconds": 5,
    "MarkStartupCompleteOnApplicationStarted": true,
    "Ui": {
      "Enabled": true,
      "EvaluationTimeSeconds": 10,
      "UIPath": "/healthchecks-ui",
      "ApiPath": "/healthchecks-api",
      "Endpoints": [
        {
          "Name": "Startup",
          "Uri": "http://localhost:5167/health/startup"
        },
        {
          "Name": "Liveness",
          "Uri": "http://localhost:5167/health/live"
        },
        {
          "Name": "Readiness",
          "Uri": "http://localhost:5167/health/ready"
        }
      ],
      "Webhooks": []
    },
    "Readiness": {
      "Database": "ConnectionStrings:SampleDbContext",
      "Redis": "Cache:DistGroups:Redis:Default:Configuration"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}