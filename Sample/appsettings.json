{
  "ConnectionStrings": {
    "AutoMigrate": "true",
    "MasterDbContext": "Host=localhost;Port=5432;User ID=admin;Password=Admin@123;Database=SampleMaster;Pooling=true;",
    "TenantDbContext": "Host=localhost;Port=5432;User ID=admin;Password=Admin@123;Database=SampleTenant;Pooling=true;"
  },
  "Cache": {
    "DefaultDistributedGroup": "Default",
    "DefaultDistributedType": "Redis",
    "MemoryInvalidation": {
      "Redis": {
        "Configuration": "127.0.0.1:6379",
        "Note": "Dedicated pub/sub for cross-node memory invalidation — not shared with DistributedGroups"
      }
    },
    "DistributedGroups": {
      "Redis": {
        "Default": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "Instance1_"
        },
        "Auth": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "SharedAuth1_"
        },
        "Big": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "Instance3_"
        }
      }
    },
    "Items": {
      "ContextData": {
        "Key": "context:{sid}",
        "DistributedSeconds": 14400,
        "MemSeconds": 180,
        "DistributedGroup": "Auth",
        "Note": "Session context — memory + Redis Auth cluster"
      },
      "ConnectionString": {
        "Key": "conn:{dbid}",
        "MemSeconds": 14400,
        "Note": "Connection string — memory only"
      },
      "ProductDemo": {
        "Key": "Product:{tenantId}:{id}",
        "MemSeconds": 300,
        "DistributedSeconds": 3600,
        "DistributedGroup": "Default",
        "Note": "Product cache demo — memory + Redis Default cluster"
      },
      "AuthUserInfo": {
        "Key": "Auth:UserInfo:{uname}:{appType}",
        "DistributedGroup": "Auth",
        "MemSeconds": 180,
        "DistributedSeconds": 14400,
        "Note": "Logged-in user by username"
      }
    }
  },
  "Authentication": {
    "Type": "ApiKey",
    "DefaultAuthenticateScheme": "Default",
    "DefaultChallengeScheme": "Default",
    "Schemes": {
      "Jwt": { "Enabled": false },
      "ApiKey": { "Enabled": true },
      "Basic": { "Enabled": false }
    },
    "Basic": {
      "Default": {
        "Realm": "Jarvis API",
        "Users": {}
      }
    },
    "ApiKey": {
      "Default": {
        "KeyName": "X-API-KEY",
        "Mode": "SingleKey",
        "Keys": []
      },
      "Integration": {
        "KeyName": "X-API-KEY",
        "Mode": "RealmKey",
        "Keys": []
      }
    },
    "Cognito": {
      "Endpoint": "https://cognito-idp.us-east-1.amazonaws.com",
      "Region": "us-east-1",
      "UserPools": {
        "key": "value"
      }
    }
  },
  "Json": {
    "IgnoreNull": true,
    "NamingPolicy": "CamelCase"
  },
  "Swagger": {
    "Enable": true,
    "Versions": [
      "v1",
      "v2"
    ],
    "ApiKeyHeaderName": "X-API-KEY",
    "ApiResponseDocumentationPathPrefixes": [
      "/api"
    ],
    "SecuritySchemes": [
      "JWT",
      "API_KEY"
    ]
  },
  "Middlewares": {
    "ApiResponseWrapper": {
      "IsEnable": true,
      "Includes": [
        "^/api"
      ],
      "Excludes": [
        "^.*\\.js$",
        "^.*\\.css$",
        "^.*\\/health$",
        "^.*\\/swagger$"
      ]
    }
  },
  "Cors": {
    "Default": {
      "AllowAnyOrigin": true,
      "AllowedOrigins": [],
      "AllowedAllHeaders": true,
      "AllowedHeaders": [],
      "AllowedAllMethods": true,
      "AllowedMethods": [],
      "AllowCredentials": false
    }
  },
  "OTEL": {
    "Name": "sample-code",
    "Namespace": "sample-code-namespace",
    "InstanceId": "hoangnh",
    "Resource": {
      "IncludeHostDetector": true,
      "IncludeContainerDetector": true
    },
    "Attributes": {},
    "Logging": {
      "IncludeConsoleExporter": false,
      "Endpoint": "http://localhost:14317",
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    },
    "Tracing": {
      "Endpoint": "http://localhost:14317",
      "Sampler": "ParentBasedRatio",
      "TraceIdRatio": 1.0,
      "TimeoutMilliseconds": 10000,
      "BatchExportProcessorOptions": {
        "ScheduledDelayMilliseconds": 5000
      },
      "HttpTraceEnrichment": {
        "CaptureRequestHeaders": true,
        "CaptureResponseHeaders": true,
        "AllowedRequestHeaderNames": [
          "traceparent",
          "tracestate",
          "x-request-id",
          "x-correlation-id",
          "x-demo-request"
        ],
        "AllowedResponseHeaderNames": [
          "content-type",
          "api-supported-versions",
          "x-demo-response"
        ],
        "MaxHeaderValueLength": 256
      },
      "AspNetCoreInstrumentation": {
        "RecordException": true,
        "ExcludedPathPrefixes": [
          "/health",
          "/healthchecks",
          "/swagger"
        ]
      },
      "HttpClient": {
        "ExcludedUrlSubstrings": []
      }
    },
    "Metric": {
      "Endpoint": "http://localhost:14317",
      "HistogramAggregation": "explicit",
      "IncludeConsoleExporter": false
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sample-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "HealthChecks": {
    "MemoryThresholdPercent": 80,
    "CpuThresholdPercent": 90,
    "ResultCacheMilliseconds": 100,
    "DetailedEndpointApiKey": "",
    "EnablePrometheusMetrics": true,
    "PrometheusMetricsPath": "/health/prometheus",
    "DefaultTimeoutSeconds": 5,
    "MarkStartupCompleteOnApplicationStarted": true,
    "Ui": {
      "Enabled": true,
      "EvaluationTimeSeconds": 10,
      "UIPath": "/healthchecks-ui",
      "ApiPath": "/healthchecks-api",
      "Endpoints": [
        {
          "Name": "Startup",
          "Uri": "http://localhost:5167/health/startup"
        },
        {
          "Name": "Liveness",
          "Uri": "http://localhost:5167/health/live"
        },
        {
          "Name": "Readiness",
          "Uri": "http://localhost:5167/health/ready"
        }
      ],
      "Webhooks": []
    },
    "Readiness": {
      "MasterDatabase": "ConnectionStrings:MasterDbContext",
      "TenantDatabase": "ConnectionStrings:TenantDbContext",
      "Redis": "Cache:DistributedGroups:Redis:Default:Configuration"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}