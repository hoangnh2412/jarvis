{
  "Cache": {
    "DefaultDistributedGroup": "Default",
    "DefaultDistributedType": "Redis",
    "MemoryInvalidation": {
      "Redis": {
        "Configuration": "127.0.0.1:6379"
      }
    },
    "DistributedGroups": {
      "Redis": {
        "Default": {
          "Configuration": "127.0.0.1:6379",
          "InstanceName": "app_"
        }
      }
    },
    "Items": {
      "ConnectionString": {
        "Key": "conn:{dbid}",
        "MemSeconds": 14400
      },
      "ContextData": {
        "Key": "context:{sid}",
        "MemSeconds": 180,
        "DistributedSeconds": 3600,
        "DistributedGroup": "Default"
      }
    }
  }
}
