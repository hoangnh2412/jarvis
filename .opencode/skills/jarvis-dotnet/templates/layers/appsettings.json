{
  "ConnectionStrings": {
    "AutoMigrate": "false",
    "AppDbContext": "Host=localhost;Port=5432;User ID=admin;Password=Admin@123;Database={product};Pooling=true;"
  },
  "Json": {
    "IgnoreNull": true,
    "NamingPolicy": "CamelCase"
  },
  "Swagger": {
    "Enable": true,
    "Versions": ["v1"],
    "ApiResponseDocumentationPathPrefixes": ["/api"]
  },
  "Middlewares": {
    "ApiResponseWrapper": {
      "IsEnable": true,
      "Includes": ["^/api"]
    }
  },
  "HealthChecks": {
    "DefaultTimeoutSeconds": 5,
    "MarkStartupCompleteOnApplicationStarted": true,
    "Readiness": {
      "Database": "ConnectionStrings:AppDbContext"
    }
  },
  "OTEL": {
    "Name": "{product}",
    "Tracing": {
      "Endpoint": "http://localhost:4317",
      "Sampler": "ParentBasedRatio",
      "TraceIdRatio": 1.0,
      "AspNetCoreInstrumentation": {
        "ExcludedPathPrefixes": ["/health", "/swagger"]
      }
    },
    "Metric": {
      "Endpoint": "http://localhost:4317"
    },
    "Logging": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
