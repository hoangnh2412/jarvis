# NuGet publish — sao chép thành .env rồi điền token thật. KHÔNG commit .env.
#   cp .env.example .env

# API key lấy từ https://www.nuget.org/account/apikeys
NUGET_API_KEY=your-nuget-api-key-here

# Nguồn đẩy (bỏ trống = nuget.org). Ví dụ GitHub Packages: https://nuget.pkg.github.com/<org>/index.json
NUGET_SOURCE=https://api.nuget.org/v3/index.json
